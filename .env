# Default env vars for the Vite build. Checked in.
# Trainees who want to override locally should create `.env.local` (gitignored).

# Canonical "Acme Widgets — Catalog" Google Sheet, published to web as CSV.
# A fresh clone runs against this URL out of the box.
VITE_WIDGETS_SHEET_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vRDcRnvmze_Pj2tdivNrUuJRJtTT1Hugiv2OUiRZYYEz1n5WHcFdBP45FucjUGwfRV0JwYijSIxm4gQ/pub?gid=0&single=true&output=csv
